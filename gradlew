#!/usr/bin/env sh
# Gradle wrapper mínimo — el wrapper real se genera con Android Studio
# o con: gradle wrapper --gradle-version 8.4

##############################################################################
# Este archivo debe ser generado con Android Studio al abrir el proyecto.
# Si clonas el repo sin Android Studio, ejecuta:
#   gradle wrapper --gradle-version 8.4
# antes de hacer push.
##############################################################################

exec gradle "$@"
